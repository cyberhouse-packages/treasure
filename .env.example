# ============================================================================
# immada – Umgebungsvariablen
# Lokale Entwicklung nutzt Docker (Postgres + MinIO). Produktion (Vercel):
# Supabase-Postgres + Vercel Blob. Siehe README → "Deployment auf Vercel".
# ============================================================================

# --- Datenbank (Postgres) ---
# LOKAL (Docker, Port 5433): beide gleich.
# PROD (Supabase): DATABASE_URL = Pooler (Port 6543, ?pgbouncer=true),
#                  DIRECT_URL   = Direktverbindung (Port 5432) für Migrationen.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/treasure?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/treasure?schema=public"

# --- Öffentliche Basis-URL (für QR-Code-Links) ---
# Lokal setzen; auf Vercel automatisch aus der Deploy-URL abgeleitet (optional).
APP_BASE_URL="http://localhost:3000"

# --- Storage-Treiber: "s3" (lokal/MinIO) oder "blob" (Vercel Blob, Prod) ---
# Ohne Angabe: "blob", falls BLOB_READ_WRITE_TOKEN gesetzt ist, sonst "s3".
STORAGE_DRIVER="s3"

# --- S3-kompatibler Storage (nur bei STORAGE_DRIVER=s3 nötig) ---
S3_ENDPOINT="http://localhost:9000"   # leer für AWS S3
S3_REGION="eu-central-1"
S3_BUCKET="treasure-audio"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true"            # true für MinIO/R2, leer/false für AWS S3
SIGNED_URL_TTL_SECONDS="300"

# --- Vercel Blob (nur bei STORAGE_DRIVER=blob nötig) ---
# Wird auf Vercel automatisch gesetzt, sobald ein Blob-Store verbunden ist.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- Admin-Provisioning Schutz ---
ADMIN_API_TOKEN="change-me-long-random-secret"
